# Beispiel fuer lokale `.env` (kopieren: Copy-Item .env.example .env)
# `.env` wird nicht committed (.gitignore). Nach `git pull` bleibt sie erhalten.
#
# Weitere Variablen (SECRET_KEY, WebAuthn, BACKUP_ENCRYPTION_PASSWORD, ...):
# siehe env_docker_example.txt und dortige Werte ebenfalls in `.env` eintragen.

# Lokaler Ordner fuer SQLite + Uploads (Host-Pfad). Im Container: /data
BIS_DATA_HOST=C:/Pfade/anpassen/bis-daten

# Lokaler Ordner fuer unverschluesselte Backups (Host). Im Container: /backup-plain
BIS_BACKUP_PLAIN_HOST=C:/Pfade/anpassen/bis-backups-plain

# Lokaler OneDrive- oder anderer Offsite-Ordner fuer verschluesselte Backups (Host).
# Im Container: /backup-encrypted
BIS_BACKUP_ENCRYPTED_HOST=C:/Pfade/anpassen/bis-backups-encrypted
