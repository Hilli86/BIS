# Pflicht: oeffentliche Basis-URL des BIS-Servers (HTTPS, ohne Pfad)
BIS_BASE_URL=https://bis.example.com

# Pflicht: Bearer-Token, der im BIS-Admin unter "Druck-Agents" erzeugt
# und EINMAL angezeigt wurde. Bei Verlust kann er rotiert werden.
BIS_AGENT_TOKEN=ersetze_mich_mit_dem_token_aus_dem_admin_ui

# Optional: Sekunden zwischen zwei Polls, wenn kein Job ansteht (Default 5).
POLL_TIMEOUT=5

# Optional: Heartbeat-Intervall in Sekunden (Default 60).
HEARTBEAT_EVERY=60

# Optional: Pfad fuer rotierende Logdatei. Leer lassen fuer reines Stdout-Logging.
LOG_FILE=
